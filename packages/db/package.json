{
  "name": "db",
  "type": "module",
  "private": true,
  "scripts": {
    "migrate-local": "drizzle-kit generate --config=./drizzle.local.config.ts && drizzle-kit migrate --config=./drizzle.local.config.ts",
    "migrate-remote": "drizzle-kit generate --config=./drizzle.remote.config.ts && drizzle-kit migrate --config=./drizzle.remote.config.ts",
    "studio": "drizzle-kit studio --config=./drizzle.local.config.ts",
    "seed": "tsx src/seed.ts"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.3",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "tsx": "^4.21.0"
  }
}
