---
import DynamicLogo from "../dynamic-logo.astro";
---

<nav
	class="fixed bg-base-100 w-full p-2 transition-colors z-50"
>
	<div class="container flex flex-row gap-2 items-center">
		<a
			href="/"
			class="btn btn-circle btn-ghost"
		>
			<DynamicLogo />
		</a>
	</div>
</nav>

<script>
	const el = document.getElementsByTagName("nav")[0];

	document.addEventListener("scroll", () => {
		if (document.documentElement.scrollTop > 24) {
			el.classList.add("shadow-lg", "bg-base-content", "text-base-100");
			el.classList.remove("bg-base-100", "text-base-content");
		} else {
			el.classList.add("bg-base-100", "text-base-content");
			el.classList.remove("shadow-lg", "bg-base-content", "text-base-100");
		}
	});
</script>