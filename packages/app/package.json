{
  "name": "app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "gleam run -m build",
    "dev": "gleam dev",
    "dev:compile:css": "tailwindcss --cwd ./src -i ./app/app.css -o ../priv/app.css --watch",
    "compile:css": "tailwindcss --cwd ./src -i ./app/app.css -o ../priv/app.css --minify"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.4"
  }
}
